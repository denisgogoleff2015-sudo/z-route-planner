PORT=3000

# Пароль обычного командира (R4/R5). Даёт доступ на редактирование карты/статей.
COMMANDER_PASSWORD=change-me

# Админский пароль — тот же доступ командира, плюс включает AI-инструменты на клиенте.
ADMIN_PASSWORD=change-me-too

# Ключ DeepSeek API для перевода статей (оставь пустым, если перевод не нужен).
DEEPSEEK_API_KEY=
